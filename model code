from tensorflow.keras import layers, models

model = models.Sequential([
    layers.Conv2D(
        32,
        (3, 3),
        activation='relu',
        input_shape=(224, 224, 3)
    ),
    layers.MaxPooling2D(),

    layers.Conv2D(
        64,
        (3, 3),
        activation='relu'
    ),
    layers.MaxPooling2D(),

    layers.Flatten(),

    layers.Dense(
        128,
        activation='relu'
    ),

    layers.Dense(
        1,
        activation='sigmoid'
    )
])

model.summary()
